# --- Таймзона ---
# Управляет И временем контейнера, И timezone в web-отпечатке (держать
# консистентно с регионом IP/номера — анти-бан).
TZ=Europe/Moscow

# --- MAX ---
MAX_PHONE=+79991234567

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=

# --- Поведение (анти-бан) ---
HUMAN_DELAY_MIN=1.0
HUMAN_DELAY_MAX=5.0

# --- Пути хранения на хосте (для переноса между серверами) ---
SESSION_HOST_DIR=./session
DATA_HOST_DIR=./data

# --- Web-отпечаток (опциональный override; дефолты в config.py) ---
# WEB_LOCALE=ru
# WEB_APP_VERSION=26.6.6
# WEB_OS_VERSION=macOS
# WEB_DEVICE_NAME=Chrome
# WEB_SCREEN=982x1512 2.0x
# WEB_USER_AGENT=Mozilla/5.0 ...
